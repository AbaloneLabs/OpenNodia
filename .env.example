# Run ./scripts/init-secrets.sh before starting the stack.
# The script writes an absolute, per-installation path here. Actual values
# remain in permission-restricted files outside the Git working tree.
OPENNODIA_SECRETS_DIR=

# Optional overrides.
ALGOD_NETWORK=testnet
ALGOD_FOLLOWER_LOOKBACK=2000
INDEXER_LIGHT_BOOTSTRAP=1
INDEXER_BOOTSTRAP_SAFETY_ROUNDS=64
INDEXER_HISTORY_ROUNDS=20000
INDEXER_PRUNE_INTERVAL_SECONDS=300
ALGOD_BIND_ADDRESS=127.0.0.1
INDEXER_BIND_ADDRESS=127.0.0.1
# The init script fills this with the primary private LAN IPv4 address.
# Set 127.0.0.1 explicitly before running it to keep the UI host-only.
OPENNODIA_BIND_ADDRESS=
